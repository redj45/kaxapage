# KaxaPage — Environment Variables
# Copy this file to .env and fill in the values.
#
#   cp .env.example .env
#
# Never commit .env to source control.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# PostgreSQL connection string.
# Format: postgres://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgres://kaxapage:kaxapage@localhost:5432/kaxapage

# Static secret token used to authenticate all admin API requests.
# !! CHANGE THIS before running in production !!
# Generate a strong random value:
#   openssl rand -hex 32
ADMIN_TOKEN=change-me-use-a-long-random-string

# ---------------------------------------------------------------------------
# Optional
# ---------------------------------------------------------------------------

# Address and port the HTTP server will bind to.
# Default: 0.0.0.0:8080
# LISTEN_ADDR=0.0.0.0:8080

# Log filter — controls verbosity of tracing output.
# Examples: info | debug | kaxapage=debug | kaxapage=trace,sqlx=warn
# Default: info
# RUST_LOG=info

# Whether to set the Secure flag on the auth cookie.
# Set to true when serving over HTTPS.
# Default: false
# COOKIE_SECURE=true
