{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n        id,\n        title,\n        status as \"status!: String\",\n        impact as \"impact!: String\",\n        started_at,\n        resolved_at\n        FROM incidents\n        WHERE workspace_id = $1\n        AND status_page_id = $2\n        AND started_at >= (NOW() AT TIME ZONE 'utc') - INTERVAL '90 days'\n        ORDER BY started_at DESC\n        ",
