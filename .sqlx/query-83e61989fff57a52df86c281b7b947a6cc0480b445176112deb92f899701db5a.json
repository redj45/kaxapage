{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT id, title, status as \"status!: String\", impact as \"impact!: String\", started_at, resolved_at\n        FROM incidents\n        WHERE workspace_id = $1\n          AND status_page_id = $2\n          AND status = 'resolved'\n        ORDER BY started_at DESC\n        LIMIT 10\n        ",
