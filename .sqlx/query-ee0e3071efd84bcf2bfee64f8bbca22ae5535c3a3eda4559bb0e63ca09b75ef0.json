  "query": "\n                SELECT id, title, status as \"status!: String\", impact as \"impact!: String\", started_at, resolved_at\n                FROM incidents\n                WHERE workspace_id = $1 AND status_page_id = $2\n                ORDER BY started_at DESC, id DESC\n                LIMIT $3\n                ",
